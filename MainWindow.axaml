<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaApp.MainWindow"
        Width="500" Height="500"
        Title="Квадратные уравнения">

    <StackPanel Margin="10" Spacing="10">

        <TextBlock Text="Введите коэффициенты a, b, c:"/>

        <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBox Name="TextBoxA" Width="100" Watermark="a"/>
            <TextBox Name="TextBoxB" Width="100" Watermark="b"/>
            <TextBox Name="TextBoxC" Width="100" Watermark="c"/>
        </StackPanel>

        <Button Content="Решить" Click="OnSolveABCClick"/>

        <TextBlock Text="Введите уравнение (2x^2+3x-1=0):"/>
        <TextBox Name="TextBoxEquation"/>

        <Button Content="Решить (строка)" Click="OnSolveStringClick"/>

        <Button Content="Загрузить файл" Click="OnLoadFileClick"/>

        <TextBlock Name="LabelResult" FontWeight="Bold"/>

        <ListBox Name="ListBoxResults" Height="200"/>

    </StackPanel>
</Window>